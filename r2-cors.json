{
	"rules": [
		{
			"id": "cryptdrive-frontend",
			"allowed": {
				"origins": ["https://cryptdrive.gauthier.workers.dev", "https://cryptdrive.io"],
				"methods": ["GET", "PUT", "POST", "DELETE", "HEAD"],
				"headers": ["*"]
			},
			"exposeHeaders": ["ETag", "Content-Length"],
			"maxAgeSeconds": 3600
		}
	]
}
